# Postgres connection URL.
# - Local dev / self-host: postgres://postgres:postgres@localhost:5432/sytrix
# - Supabase: use the "Transaction pooler" URL (port 6543) for serverless deploys.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sytrix

# HS256 secret for access tokens. Minimum 64 bytes when UTF-8 encoded (OWASP 2024). Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string-that-is-at-least-64-bytes-when-utf8-encoded-xxxxxxxxxx

# "development" | "production" | "test"
NODE_ENV=development

# Port for self-host mode (ignored on Vercel).
PORT=3000

# Comma-separated list of allowed CORS origins (required in production).
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# In development, defaults to http://localhost:3000 and http://localhost:5173.
# ALLOWED_ORIGINS=

# Set to "true" when the server runs behind a trusted reverse proxy (nginx, Cloudflare, Vercel edge)
# that sets X-Forwarded-For authoritatively. Leave "false" otherwise to prevent IP spoofing.
TRUST_PROXY=false

# Separate HMAC secret for hashing recovery codes. Falls back to JWT_SECRET if unset, but
# using a distinct secret is strongly recommended so that a JWT_SECRET rotation does not
# invalidate existing recovery codes (and vice versa). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# RECOVERY_HMAC_SECRET=
