# Postgres connection URL.
# - Local dev / self-host: postgres://postgres:postgres@localhost:5432/sytrix
# - Supabase: use the "Transaction pooler" URL (port 6543) for serverless deploys.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sytrix

# HS256 secret for access tokens. Minimum 32 bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes

# "development" | "production" | "test"
NODE_ENV=development

# Port for self-host mode (ignored on Vercel).
PORT=3000
